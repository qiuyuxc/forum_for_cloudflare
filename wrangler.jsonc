{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "forum",
	"main": "src/index.ts",
	"compatibility_date": "2025-09-25",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "forum_db",
			"database_name": "forum-db",
			"database_id": "77b2c361-d771-4bac-b19d-d52413567b52",
			"remote": true,
			"migrations_dir": "migrations"
		}
	],
	"durable_objects": {
		"bindings": [
			{
				"name": "WS_MANAGER",
				"class_name": "SSEHub"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_sqlite_classes": ["ForumWebSocket"]
		},
		{
			"tag": "v2",
			"renamed_classes": [
				{ "from": "ForumWebSocket", "to": "SSEHub" }
			]
		}
	]
}
